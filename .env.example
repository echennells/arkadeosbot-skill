# Arkade Wallet Mnemonic (BIP39 - 12 or 24 words)
# Generate a new one by running: node examples/wallet-setup.js
# Or provide your own BIP39 mnemonic
ARK_MNEMONIC=

# Arkade Server URL
# Mainnet: https://arkade.computer
# Mutinynet: (varies)
# Regtest: http://localhost:7070
ARK_SERVER_URL=https://arkade.computer

# Network: bitcoin, mutinynet, regtest
ARK_NETWORK=bitcoin

# Esplora URL (optional, defaults based on network)
# ESPLORA_URL=https://mempool.space/api

# Boltz API URL (optional, defaults based on network)
# BOLTZ_URL=https://api.ark.boltz.exchange

# Delegator URL for automatic VTXO renewal (optional, defaults based on network)
# Free on mainnet. Set to empty string to disable delegation.
# ARK_DELEGATOR_URL=https://delegate.arkade.money
